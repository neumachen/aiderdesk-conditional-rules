{
  "name": "aiderdesk-conditional-rules",
  "version": "0.1.0",
  "description": "AiderDesk extension that conditionally loads rule files based on YAML frontmatter (globs:, alwaysApply:) matched against the current task's context files. Cursor-style on-demand rule selection for AiderDesk.",
  "main": "index.ts",
  "author": "Kareem Hepburn",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "picomatch": "^4.0.2"
  },
  "devDependencies": {
    "@aiderdesk/extensions": "^0.15.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/picomatch": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
